# Required for the assignment PostgreSQL path.
DATABASE_URL=postgresql+psycopg2://recipe_user:recipe_pass@localhost:5432/recipe_planner

# Gemini via LangChain. Either variable name is supported by the app.
GOOGLE_API_KEY=your_google_gemini_api_key_here
# GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional runtime settings.
GEMINI_MODEL=gemini-2.5-flash
USE_LLM=true
REQUIRE_LLM=true
REQUEST_TIMEOUT_SECONDS=18
MAX_SCRAPED_CHARS=14000
